---
import { SITE } from "../config/site.js";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = SITE.name ?? SITE.siteName;
const description = SITE.description ?? SITE.siteDescription;
const TELEGRAM_URL = SITE.telegram ?? SITE.telegramUrl;
---

<BaseLayout title={title} description={description} canonicalPath="/">
  <header class="nav">
    <div class="container nav-inner">
      <div class="brand">
        <span class="brand-badge"></span>
        <span>{title}</span>
      </div>

      <nav class="nav-links">
        <a href="#guias">Guias</a>
        <a href="#faq">FAQ</a>
        <a class="btn btn-small" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">Telegram</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-left">
          <div class="kicker">
            <span class="dot"></span> Guias claros e diretos
          </div>

          <h1 class="h1">Guias e explicações claras (Portugal)</h1>
          <p class="lead">{description}</p>

          <div class="hero-ctas">
            <a class="btn btn-primary" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">
              Entrar no Telegram
            </a>
            <a class="btn" href="#guias">Ver guias</a>
          </div>

          <div class="trust">
            <span>Sem promessas</span>
            <span>Informação clara</span>
            <span>Leitura rápida</span>
          </div>
        </div>

        <aside class="hero-right">
          <div class="media">
            <div class="media-overlay">
              <span class="pill">Atualizações</span>
              <span class="pill">PT-PT</span>
            </div>
          </div>

          <div class="card">
            <h3>O que é este site?</h3>
            <p>Um hub de guias, explicações e boas práticas.</p>
          </div>
        </aside>
      </div>
    </section>

    <!-- GUIAS -->
    <section id="guias" class="section">
      <div class="container">
        <h2>Guias</h2>
        <p class="lead">Começa pelo essencial e avança para os detalhes.</p>

        <ul>
          <li><a href="/guia-iniciante">Guia do Iniciante</a></li>
          <li><a href="/como-ler-condicoes">Como ler condições (sem complicações)</a></li>
          <li><a href="/gestao-de-limites">Gestão de limites: boas práticas</a></li>
        </ul>

        <p style="margin-top:16px;">
          <a class="btn btn-small" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">
            Receber atualizações no Telegram
          </a>
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <div class="container">
        <h2>FAQ</h2>

        <details>
          <summary>Este site promete ganhos?</summary>
          <p>Não. É um site informativo e educativo. Não existem garantias de resultados.</p>
        </details>

        <details>
          <summary>Como acompanho atualizações?</summary>
          <p>A forma mais simples é pelo Telegram, onde partilhamos novidades e links.</p>
        </details>

        <details>
          <summary>Onde vejo avisos legais e privacidade?</summary>
          <p>Estão disponíveis no rodapé em “Aviso Legal” e “Privacidade”.</p>
        </details>
      </div>
    </section>

    <footer class="container" style="padding: 24px 0; opacity: .85;">
      <a href="/disclaimer">Aviso Legal</a> · <a href="/privacidade">Privacidade</a>
    </footer>
  </main>
</BaseLayout>
