---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site.js";

const title = `Gestão de limites: boas práticas — ${SITE.name ?? SITE.siteName}`;
const description = "Práticas simples para definir limites e manter decisões controladas e consistentes.";
const TELEGRAM_URL = SITE.telegram ?? SITE.telegramUrl;
---

<BaseLayout title={title} description={description} canonicalPath="/gestao-de-limites">
  <main class="container" style="padding: 32px 0;">
    <h1>Gestão de limites: boas práticas</h1>
    <p>
      Este site é informativo. Se decides jogar, o mínimo é definir limites claros para evitar decisões erradas por impulso.
    </p>

    <h2>3 regras práticas</h2>
    <ul>
      <li><strong>Limite de tempo</strong>: define quanto tempo vais dedicar.</li>
      <li><strong>Limite de valor</strong>: decide um teto e respeita.</li>
      <li><strong>Pausa</strong>: evita “recuperar perdas” no calor do momento.</li>
    </ul>

    <p style="margin-top:24px;">
      <a class="btn btn-primary" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">
        Entrar no Telegram
      </a>
    </p>

    <p style="margin-top:20px;">
      Voltar: <a href="/como-ler-condicoes">Como ler condições</a> · <a href="/">Homepage</a>
    </p>
  </main>
</BaseLayout>
