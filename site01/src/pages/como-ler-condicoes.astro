---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site.js";

const title = `Como ler condições (sem complicações) — ${SITE.name ?? SITE.siteName}`;
const description = "Um método simples para ler condições: o que é exigido, prazos, limites e jogos elegíveis.";
const TELEGRAM_URL = SITE.telegram ?? SITE.telegramUrl;
---

<BaseLayout title={title} description={description} canonicalPath="/como-ler-condicoes">
  <main class="container" style="padding: 32px 0;">
    <h1>Como ler condições (sem complicações)</h1>
    <p>
      A maioria das dúvidas vem de 4 pontos. Se verificares isto, já ficas à frente da maioria.
    </p>

    <h2>Checklist (4 pontos)</h2>
    <ul>
      <li><strong>O que recebes</strong>: bónus, rodadas, cashback, etc.</li>
      <li><strong>O que é exigido</strong>: requisitos de apostas (wagering), se existir.</li>
      <li><strong>Prazos</strong>: validade da oferta e prazo para cumprir regras.</li>
      <li><strong>Limites</strong>: cap de levantamento e restrições adicionais.</li>
    </ul>

    <p style="margin-top:24px;">
      <a class="btn btn-primary" href={TELEGRAM_URL} target="_blank" rel="noopener noreferrer">
        Receber atualizações no Telegram
      </a>
    </p>

    <p style="margin-top:20px;">
      Próximo guia: <a href="/gestao-de-limites">Gestão de limites</a> ·
      <a href="/guia-iniciante">Guia do iniciante</a> · <a href="/">Homepage</a>
    </p>
  </main>
</BaseLayout>
