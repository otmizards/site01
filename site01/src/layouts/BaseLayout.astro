---
import { SITE } from "../config/site.js";

const {
  title = SITE.name ?? SITE.siteName ?? "360Wins Portugal",
  description = SITE.description ?? SITE.siteDescription ?? "Informação clara sobre casino online em Portugal.",
  canonicalPath = "/",
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, SITE.site ?? SITE.url ?? "https://360winspt.com").toString();
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- CSS global único (obrigatório) -->
    <link rel="stylesheet" href="/styles/global.css" />
  </head>

  <body>
    <slot />
  </body>
</html>
